{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": "/home/alunduil/.claude/statusline.sh"
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "/home/alunduil/.claude/hooks/pr-draft-guard.sh",
            "type": "command"
          }
        ],
        "matcher": "mcp__github__create_pull_request(_with_copilot)?"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/alunduil/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/alunduil/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/alunduil/.claude/hooks/pre-commit-edit-guard.sh"
          }
        ],
        "matcher": "Edit|Write|MultiEdit|NotebookEdit"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
