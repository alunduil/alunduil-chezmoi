#!/usr/bin/env bash
# Manage ~/.claude/settings.json without re-syncing when a new key appears.
# Claude rewrites this file in its own key order; chezmoi reads that live
# copy on stdin and overwrites only the keys it owns (policy plus paths to
# chezmoi-deployed scripts), leaving theme and enabledPlugins for Claude to
# mutate at runtime. jq + preserves on-disk key order and appends new keys,
# so chezmoi's target matches Claude's serialization regardless of insertion.
set -euo pipefail

jq --slurp '(.[0] // {}) + {
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_DISABLE_ALTERNATE_SCREEN": "1"
  },
  "permissions": {
    "allow": [
      "BashOutput(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "MultiEdit(*)",
      "NotebookEdit(*)",
      "Read(*)",
      "TodoWrite(*)",
      "Write(*)",
      "mcp__claude_ai_Readwise__reader_get_document_details",
      "mcp__claude_ai_Readwise__reader_get_document_highlights",
      "mcp__claude_ai_Readwise__reader_get_export_documents_status",
      "mcp__claude_ai_Readwise__reader_list_documents",
      "mcp__claude_ai_Readwise__reader_list_tags",
      "mcp__claude_ai_Readwise__reader_search_documents",
      "mcp__claude_ai_Readwise__reader_export_documents",
      "mcp__claude_ai_Readwise__readwise_get_daily_review",
      "mcp__claude_ai_Readwise__readwise_list_highlights",
      "mcp__claude_ai_Readwise__readwise_search_highlights",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id",
      "mcp__github__get_commit",
      "mcp__github__get_file_contents",
      "mcp__github__get_label",
      "mcp__github__get_latest_release",
      "mcp__github__get_me",
      "mcp__github__get_release_by_tag",
      "mcp__github__get_tag",
      "mcp__github__get_team_members",
      "mcp__github__get_teams",
      "mcp__github__issue_read",
      "mcp__github__list_branches",
      "mcp__github__list_commits",
      "mcp__github__list_issue_fields",
      "mcp__github__list_issue_types",
      "mcp__github__list_issues",
      "mcp__github__list_pull_requests",
      "mcp__github__list_releases",
      "mcp__github__list_repository_collaborators",
      "mcp__github__list_tags",
      "mcp__github__search_code",
      "mcp__github__search_commits",
      "mcp__github__search_issues",
      "mcp__github__search_pull_requests",
      "mcp__github__search_repositories",
      "mcp__github__search_users",
      "Bash(apt-cache:*)",
      "Bash(awk:*)",
      "Bash(basename:*)",
      "Bash(bats:*)",
      "Bash(bun:*)",
      "Bash(cargo:*)",
      "Bash(cat:*)",
      "Bash(chezmoi:*)",
      "Bash(cmp:*)",
      "Bash(codecov-api:*)",
      "Bash(cut:*)",
      "Bash(date:*)",
      "Bash(devcontainer:*)",
      "Bash(diff:*)",
      "Bash(dirname:*)",
      "Bash(docker:*)",
      "Bash(echo:*)",
      "Bash(env)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(go:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(less:*)",
      "Bash(ls:*)",
      "Bash(make:*)",
      "Bash(mkdir:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pip:*)",
      "Bash(pipx:*)",
      "Bash(pnpm:*)",
      "Bash(pre-commit:*)",
      "Bash(printf:*)",
      "Bash(pwd)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(rg:*)",
      "Bash(rustc:*)",
      "Bash(rustup:*)",
      "Bash(sed:*)",
      "Bash(sha256sum:*)",
      "Bash(shellcheck:*)",
      "Bash(shfmt:*)",
      "Bash(sort:*)",
      "Bash(stat:*)",
      "Bash(systemd-analyze:*)",
      "Bash(tail:*)",
      "Bash(tee:*)",
      "Bash(terraform:*)",
      "Bash(test:*)",
      "Bash(touch:*)",
      "Bash(tr:*)",
      "Bash(tree:*)",
      "Bash(uniq:*)",
      "Bash(uv:*)",
      "Bash(vale:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(whoami)",
      "Bash(xargs:*)",
      "Bash(yarn:*)",
      "Bash(yq:*)",
      "Bash(zellij:*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push*--force*)",
      "Bash(git push -f*)",
      "Bash(git push* -f*)",
      "Bash(git push*main*)",
      "Read({{ .chezmoi.homeDir }}/.claude/.credentials.json)",
      "Read({{ .chezmoi.homeDir }}/.gnupg/**)",
      "Read({{ .chezmoi.homeDir }}/.ssh/**)"
    ],
    "ask": [
      "Bash(bash -c*)",
      "Bash(chezmoi apply*)",
      "Bash(docker system prune*)",
      "Bash(docker volume rm*)",
      "Bash(find* -delete*)",
      "Bash(find* -exec*)",
      "Bash(find* -ok*)",
      "Bash(gh api*)",
      "Bash(git config*)",
      "Bash(git remote add*)",
      "Bash(node -e*)",
      "Bash(perl -e*)",
      "Bash(python -c*)",
      "Bash(python3 -c*)",
      "Bash(rm:*)",
      "Bash(sh -c*)",
      "Bash(sudo:*)",
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(xargs rm*)",
      "Bash(xargs* rm*)",
      "Bash(xargs sudo*)",
      "Bash(xargs* sudo*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__github__create_pull_request(_with_copilot)?",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/pr-draft-guard.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/pre-commit-edit-guard.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "{{ .chezmoi.homeDir }}/.claude/statusline.sh"
  }
}
'
