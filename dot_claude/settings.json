{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/pr-draft-guard.sh",
            "type": "command"
          }
        ],
        "matcher": "mcp__github__create_pull_request(_with_copilot)?"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/zellij/plugins/zellaude-hook.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash",
      "BashOutput(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "MultiEdit(*)",
      "NotebookEdit(*)",
      "Read(*)",
      "TodoWrite(*)",
      "Write(*)"
    ],
    "ask": [
      "Bash(rm:*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push*--force*)",
      "Bash(git push*main*)"
    ]
  }
}
