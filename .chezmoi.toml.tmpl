{{- $role := or (env "CHEZMOI_ROLE") "workstation" -}}
# recipient is the public half of the age key (private half lives in key.txt,
# uncommitted), so exposing it here leaks nothing.
encryption = "age"

[age]
	identity = "~/.config/chezmoi/key.txt"
	recipient = "age13vgd4mk5a74fazamw09xqaq8yughtmlhepuqsdy2t300j4vldg9quf77j5"

[data]
	# Host class, explicit per host (not detected): set CHEZMOI_ROLE at
	# bootstrap, else "workstation". Gates sources via .chezmoiignore. See
	# docs/explanation/architecture.md, "Host roles".
	role = {{ $role | quote }}
