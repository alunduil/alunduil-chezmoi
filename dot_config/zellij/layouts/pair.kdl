// Deep-pairing layout: Claude Code (40%) alongside lazygit (60%). The editing
// surface is VS Code in its own window; this layout is for the "watch the
// changes, drive Claude" side of pairing.
//
// Template:
//   zellaude   (1 line) — per-tab Claude Code activity + tab list
//   zjstatus   (1 line) — current branch (5s) + open-PR list (60s)
//   children   (the panes)
//   status-bar (1 line, clipped) — mode indicator only; tips suppressed
//
// Invoke:
//   zellij --layout pair                         # fresh session
//   zellij action new-tab --layout pair          # new tab in current session
//   Alt+p                                        # keybind, same as above
//                                                # (git-repo-picker renames the
//                                                # spawned tab to the repo name)

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellaude"
        }
        pane size=1 borderless=true {
            plugin location="zjstatus" {
                format_left  "#[bg=16]{command_branch}{command_prs}"
                format_space "#[bg=16]"
                format_right "#[bg=16]"
                command_branch_command    "bash -lc zellij-branch-status"
                command_branch_format     "{stdout}"
                command_branch_rendermode "dynamic"
                command_branch_interval   "5"
                command_prs_command       "bash -lc zellij-pr-status"
                command_prs_format        "{stdout}"
                command_prs_rendermode    "dynamic"
                command_prs_interval      "60"
            }
        }
        children
        pane size=1 borderless=true {
            plugin location="status-bar"
        }
    }
    tab name="pair" focus=true {
        pane split_direction="vertical" {
            pane size="40%" name="claude" command="claude"
            pane size="60%" name="lazygit" command="lazygit"
        }
    }
}
