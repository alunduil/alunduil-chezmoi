#!/usr/bin/env python3
"""Repo-wide vale gate: fail on any warning-level finding and on per-file
suggestion regressions against a committed baseline (issue #310).

vale's exit code reflects only error-severity alerts -- --minAlertLevel is a
display filter, not a gate -- so warnings and suggestions never block on their
own. This parses --output=JSON instead: zero tolerance for warnings,
regression-only for suggestions (the standing suggestion debt is too large to
clear at once, so the baseline freezes it per file and fails only on growth).

The error-severity gate stays with the pre-commit vale hook; this is the
stricter CI-only layer on top. Run `script/checks/vale --update` after
intentionally clearing suggestions to ratchet the baseline down.
"""

import json
import subprocess
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
BASELINE = HERE / "vale-baseline.json"

# The file set the pre-commit vale hook lints: every tracked *.md minus the
# dirs that hook excludes. Keep in sync with the `exclude:` on the vale hook
# in .pre-commit-config.yaml.
EXCLUDE_PREFIXES = ("CLAUDE.md", "dot_claude/", ".claude/", ".vale/styles/")


def repo_root():
    return Path(
        subprocess.check_output(
            ["git", "rev-parse", "--show-toplevel"], text=True
        ).strip()
    )


def linted_files(root):
    out = subprocess.check_output(["git", "ls-files", "*.md"], cwd=root, text=True)
    return [f for f in out.splitlines() if f and not f.startswith(EXCLUDE_PREFIXES)]


def run_vale(root, files):
    proc = subprocess.run(
        ["vale", "--output=JSON", "--minAlertLevel=suggestion", *files],
        cwd=root,
        capture_output=True,
        text=True,
    )
    # vale exits non-zero on error-severity alerts; gating those is the
    # pre-commit hook's job. Here only the JSON it always emits matters.
    if not proc.stdout.strip():
        sys.exit(f"vale produced no output:\n{proc.stderr}")
    return json.loads(proc.stdout)


def suggestion_counts(findings):
    """Map of file -> suggestion count, omitting files with none."""
    counts = {}
    for path, alerts in findings.items():
        n = sum(1 for a in alerts if a["Severity"] == "suggestion")
        if n:
            counts[path] = n
    return counts


def blocking_findings(findings):
    """warning/error alerts as sorted 'file:line [Check] message' strings."""
    out = []
    for path, alerts in findings.items():
        for a in alerts:
            if a["Severity"] != "suggestion":
                out.append(f"{path}:{a['Line']} [{a['Check']}] {a['Message']}")
    return sorted(out)


def regressions(counts, baseline):
    """Files whose suggestion count exceeds their baseline allowance."""
    out = []
    for path in sorted(counts):
        allowed = baseline.get(path, 0)
        if counts[path] > allowed:
            out.append(f"{path}: {counts[path]} suggestions, baseline {allowed}")
    return out


def stale_baseline(counts, baseline):
    """Baseline entries now looser than reality -- candidates to ratchet down."""
    out = []
    for path in sorted(baseline):
        actual = counts.get(path, 0)
        if actual < baseline[path]:
            out.append(f"{path}: {actual} suggestions, baseline {baseline[path]}")
    return out


def main(argv):
    root = repo_root()
    files = linted_files(root)
    findings = run_vale(root, files)
    counts = suggestion_counts(findings)

    if "--update" in argv[1:]:
        BASELINE.write_text(json.dumps(dict(sorted(counts.items())), indent=2) + "\n")
        print(f"wrote {BASELINE.name}: {sum(counts.values())} suggestions "
              f"across {len(counts)} files")
        return 0

    baseline = json.loads(BASELINE.read_text()) if BASELINE.exists() else {}
    blocking = blocking_findings(findings)
    regs = regressions(counts, baseline)
    stale = stale_baseline(counts, baseline)

    if stale:
        print(
            f"note: {BASELINE.name} is looser than reality; run "
            "`script/checks/vale --update` to ratchet down:",
            file=sys.stderr,
        )
        for s in stale:
            print(f"  {s}", file=sys.stderr)

    if blocking:
        print("vale: warning-level findings (must be zero):", file=sys.stderr)
        for b in blocking:
            print(f"  {b}", file=sys.stderr)
    if regs:
        print("vale: suggestion regressions vs baseline:", file=sys.stderr)
        for r in regs:
            print(f"  {r}", file=sys.stderr)

    if blocking or regs:
        return 1
    print(
        f"vale: {len(files)} files, 0 warnings, "
        f"{sum(counts.values())} suggestions within baseline"
    )
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv))
