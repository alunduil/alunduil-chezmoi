#!/usr/bin/env bash
set -euo pipefail

# casey/just tags have no `v` prefix (unlike zellij/lazygit/act), so the
# version variable and Renovate matcher both use bare semver.
JUST_VERSION="1.51.0"
ARCH="x86_64-unknown-linux-musl"

# shellcheck source-path=SCRIPTDIR source=lib.sh
. "$(dirname "$0")/lib.sh"

parse_bin_dir "$@"

bin="$BIN_DIR/just"
if [ -x "$bin" ] && "$bin" --version 2>/dev/null | grep -qF "$JUST_VERSION"; then
  printf '==> just: %s already installed at %s\n' "$JUST_VERSION" "$bin" >&2
  exit 0
fi

printf '==> just: downloading %s\n' "$JUST_VERSION" >&2
tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT

base="https://github.com/casey/just/releases/download/${JUST_VERSION}"
asset="just-${JUST_VERSION}-${ARCH}.tar.gz"
curl -fsSL -o "$tmp/$asset" "$base/$asset"
curl -fsSL -o "$tmp/SHA256SUMS" "$base/SHA256SUMS"

expected="$(expected_from_checksums "$tmp/SHA256SUMS" "$asset")"
verify_sha256 "$tmp/$asset" "$expected"

tar -xzf "$tmp/$asset" -C "$tmp" just
mkdir -p "$BIN_DIR"
install -m 0755 "$tmp/just" "$bin"
