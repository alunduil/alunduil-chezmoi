#!/usr/bin/env bash
set -euo pipefail

VALE_VERSION="v3.14.2"
ARCH="Linux_64-bit"

# shellcheck source-path=SCRIPTDIR source=lib.sh
. "$(dirname "$0")/lib.sh"

parse_bin_dir "$@"

bin="$BIN_DIR/vale"
if [ -x "$bin" ] && "$bin" --version 2>/dev/null | grep -qF "${VALE_VERSION#v}"; then
  printf '==> vale: %s already installed at %s\n' "$VALE_VERSION" "$bin" >&2
  exit 0
fi

printf '==> vale: downloading %s\n' "$VALE_VERSION" >&2
tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT

base="https://github.com/vale-cli/vale/releases/download/${VALE_VERSION}"
asset="vale_${VALE_VERSION#v}_${ARCH}.tar.gz"
checksums="vale_${VALE_VERSION#v}_checksums.txt"
curl -fsSL -o "$tmp/$asset" "$base/$asset"
curl -fsSL -o "$tmp/checksums.txt" "$base/$checksums"

expected="$(expected_from_checksums "$tmp/checksums.txt" "$asset")"
verify_sha256 "$tmp/$asset" "$expected"

tar -xzf "$tmp/$asset" -C "$tmp" vale
mkdir -p "$BIN_DIR"
install -m 0755 "$tmp/vale" "$bin"
