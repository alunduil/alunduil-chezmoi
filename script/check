#!/usr/bin/env bash
# Run every verification this repo defines. Missing tools are reported
# as failures (not silently skipped) so a green run means every check
# actually ran. CI runs these as separate workflows for parallel
# execution; this is the local one-stop equivalent.
#
# Exit 0 = everything passed and every required tool was installed.
# Exit 1 = at least one check failed or one tool was missing.

set -uo pipefail

declare -a results=()

run() {
  local name="$1" tool="$2" install_hint="$3"
  shift 3
  printf '\n=== %s ===\n' "$name"
  if ! command -v "$tool" >/dev/null 2>&1; then
    printf 'SKIP: %s not installed\n' "$tool"
    results+=("MISSING $name (install $tool: $install_hint)")
    return
  fi
  if "$@"; then
    results+=("PASS    $name")
  else
    results+=("FAIL    $name")
  fi
}

run 'pre-commit'          pre-commit 'pipx install pre-commit' \
  pre-commit run --all-files

run 'bats'                bats       'apt install bats' \
  bats test/

run 'check-zellij-config' zellij     'see run_once_02_*.sh.tmpl' \
  script/check-zellij-config

run 'check-chezmoi-apply' chezmoi    'see run_once_02_*.sh.tmpl' \
  script/check-chezmoi-apply

run 'lychee'              lychee     'cargo install lychee' \
  lychee README.md dot_config/zellij/config.kdl

printf '\n=== Summary ===\n'
exit_code=0
for r in "${results[@]}"; do
  printf '%s\n' "$r"
  case "$r" in
    FAIL*|MISSING*) exit_code=1 ;;
  esac
done
exit "$exit_code"
