#!/usr/bin/env bash
# Verify $HOME/.claude/* hook commands in the rendered settings.json
# exist. Catches template typos pointing at hooks we haven't written.
# Out of scope: external integrations (e.g. zellaude under
# ~/.config/zellij/plugins/), prefix-translation, permission bits —
# those are chezmoi's job.

set -euo pipefail

dest="$(mktemp -d)"
trap 'rm -rf "$dest"' EXIT

chezmoi apply --source=. --destination="$dest" --exclude=scripts

fail=0
while IFS= read -r cmd; do
  resolved="${cmd/\$HOME/$dest}"
  if [ ! -f "$resolved" ]; then
    printf 'FAIL: hook command %s not found at %s\n' "$cmd" "$resolved" >&2
    fail=1
  fi
done < <(jq -r '.. | .command? // empty | select(startswith("$HOME/.claude/"))' "$dest/.claude/settings.json")

exit "$fail"
