#!/usr/bin/env bash
# Registers Uptime Robot's remote MCP with Claude Code. UR uses bearer-token
# auth (not OAuth like the Cloudflare MCPs in script 07-before), so the token
# is passed via --header and ends up baked into ~/.claude.json.
#
# Why run_onchange_after instead of run_once_before:
#   - _after_: the token template must render to ~/.config/uptimerobot/token
#     before we read it, which only happens after files are applied.
#   - run_onchange (keyed on the vault token's hash below): when the token
#     rotates in 1Password, the rendered hash changes, this script reruns, and
#     the stale token in ~/.claude.json gets replaced.
#
# Rerun-on-rotation trigger: hash of the vault token embedded below. When the
# token rotates in 1Password, this hash changes, the rendered script content
# changes, and chezmoi reruns this script -- which removes the stale
# ~/.claude.json entry and re-adds the new one. The env guard keeps the hash
# renderable without an op session (CI applies with --exclude=scripts, so this
# never evaluates there).
# token-hash: {{ if env "OP_SERVICE_ACCOUNT_TOKEN" }}{{ onepasswordRead "op://chezmoi/uptimerobot/token" | sha256sum }}{{ else }}no-op-token{{ end }}

set -euo pipefail

log() { printf '==> %s\n' "$*" >&2; }

token_file="$HOME/.config/uptimerobot/token"
if [ ! -r "$token_file" ]; then
  log "uptimerobot: token not deployed at $token_file, skipping"
  exit 0
fi

token="$(<"$token_file")"

# Idempotent re-register: remove any existing entry (no-op if absent) and add
# afresh so a rotated token replaces the stale one in ~/.claude.json.
claude mcp remove uptimerobot --scope user >/dev/null 2>&1 || true
log "uptimerobot: registering"
claude mcp add uptimerobot --transport http --scope user \
  https://mcp.uptimerobot.com/mcp \
  --header "Authorization: Bearer ${token}"
