#!/usr/bin/env bash
# Registers Claude Code MCP servers via `claude mcp add --scope user`. State
# lives in ~/.claude.json -- a stateful file Claude Code writes to and chezmoi
# doesn't manage -- which is why registration happens in the bootstrap rather
# than via a chezmoi-deployed config file. OAuth pops a browser on first use.
# Requires `claude` (installed in script 03).
#
# Idempotency here is check-and-skip (grep `claude mcp list`), not the
# remove-and-re-add the run_onchange_after_07-* MCP scripts use. These are
# static endpoint URLs, so skipping when already present is safe; the
# run_onchange scripts re-add because they carry rotating secrets whose
# change must take effect.

set -euo pipefail

log() { printf '==> %s\n' "$*" >&2; }

# ----------------------------------------------------------------- Cloudflare
declare -A CLOUDFLARE_MCP=(
  [cloudflare-dns-analytics]="https://dns-analytics.mcp.cloudflare.com/mcp"
  [cloudflare-graphql]="https://graphql.mcp.cloudflare.com/mcp"
  [cloudflare-docs]="https://docs.mcp.cloudflare.com/mcp"
)
for name in "${!CLOUDFLARE_MCP[@]}"; do
  if claude mcp list 2>/dev/null | grep -q "^${name}:"; then
    log "${name}: already registered"
  else
    log "${name}: registering"
    claude mcp add "$name" --transport http --scope user "${CLOUDFLARE_MCP[$name]}"
  fi
done

# --------------------------------------------------------------------- GitHub
# Official Copilot MCP server. OAuth like Cloudflare; tools land under
# mcp__github__*, which pr-draft-guard.sh keys on for the draft-PR enforcement.
if claude mcp list 2>/dev/null | grep -q "^github:"; then
  log "github: already registered"
else
  log "github: registering"
  claude mcp add github --transport http --scope user \
    https://api.githubcopilot.com/mcp/
fi

log "claude mcp servers complete"
