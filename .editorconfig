root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.sh]
indent_style = space
indent_size = 2

[*.sh.tmpl]
indent_style = space
indent_size = 2

[*.kdl]
indent_style = space
indent_size = 4

[*.json]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.toml]
indent_style = space
indent_size = 2

[*.yml]
indent_style = space
indent_size = 2
