// unattended-upgrades policy for this host. Full option reference -- every
// knob omitted below -- ships at /usr/share/unattended-upgrades/50unattended-upgrades.

// Which packages auto-upgrade: Debian security + updates, plus every
// third-party apt repo .chezmoiscripts/run_once_before_01 adds, so installed tools track
// upstream on the same timer. ${distro_codename} is expanded by
// unattended-upgrades at run time; fixed-codename repos pin what they publish.
Unattended-Upgrade::Origins-Pattern {
        "origin=Debian,codename=${distro_codename}-updates";
        "origin=Debian,codename=${distro_codename},label=Debian";
        "origin=Debian,codename=${distro_codename},label=Debian-Security";
        "origin=Debian,codename=${distro_codename}-security,label=Debian-Security";
        "origin=Artifactory,codename=${distro_codename}";       // HashiCorp (Terraform)
        "origin=gh,codename=stable";                            // GitHub CLI
        "origin=Tailscale,codename=${distro_codename}";         // Tailscale
        "origin=. xenial,codename=xenial";                      // Signal
        "origin=code stable,codename=stable";                   // VS Code
        "origin=Docker,archive=${distro_codename}";             // Docker CE (publishes Suite, not Codename)
        "site=prerelease.keybase.io";                           // Keybase (no repo metadata)
};

// Autoremove unused dependencies after each run.
Unattended-Upgrade::Remove-Unused-Dependencies "true";

// Attended box -- never reboot automatically (see #228). Moot on Crostini
// regardless: the kernel is ChromeOS's, so a reboot can't pick up a new one.
// needrestart (.chezmoiscripts/run_onchange_before_04) restarts services onto upgraded libraries
// in place instead, which is the part that actually matters here. See #238.
Unattended-Upgrade::Automatic-Reboot "false";

// Pause on battery. Real here -- powermgmt-base (installed by
// .chezmoiscripts/run_onchange_before_04) reads the AC line; battery is rare on this always-plugged box.
Unattended-Upgrade::OnlyOnACPower "true";

// Pause on metered connections. Fails open under Crostini (no NetworkManager
// to query); meaningful on a workstation that runs one.
Unattended-Upgrade::Skip-Updates-On-Metered-Connections "true";

// Verbose logs -- the only inspection surface we keep (no mail/toast, see #228).
Unattended-Upgrade::Verbose "true";
