#!/usr/bin/env bash
# Bootstrap script run by chezmoi on first apply (and again whenever this file's
# hash changes). Installs the toolchain for the Claude Code + Claustre + Zellij
# workflow. Must be idempotent — safe to re-run on an already-bootstrapped host.
#
# Canonical installers only: rustup.rs for Rust, nvm for Node. Debian apt Node
# and apt chezmoi/rustc are avoided by design (they lag upstream).

set -euo pipefail

log() { printf '==> %s\n' "$*" >&2; }

# -------------------------------------------------------------------- apt pkgs
# zellij is intentionally not here: not in Debian bookworm. Installed below
# from GitHub releases (pre-built musl binary).
APT_PACKAGES=(gh zsh ripgrep fd-find jq unzip age)
missing=()
for pkg in "${APT_PACKAGES[@]}"; do
  dpkg -s "$pkg" >/dev/null 2>&1 || missing+=("$pkg")
done
if (( ${#missing[@]} > 0 )); then
  log "apt: installing ${missing[*]}"
  sudo apt-get update
  sudo apt-get install -y "${missing[@]}"
else
  log "apt: all packages present"
fi

# ---------------------------------------------------------------- tailscale
# System daemon. The official installer is idempotent and handles apt
# signing key + repo + package in one go. `tailscale up` (interactive
# browser auth) is a separate per-machine manual step -- see README.
if ! command -v tailscale >/dev/null 2>&1; then
  log "tailscale: running official installer"
  curl -fsSL https://tailscale.com/install.sh | sh
else
  log "tailscale: already installed"
fi
sudo systemctl enable --now tailscaled

# ------------------------------------------------------------------- zellij
ZELLIJ_VERSION="v0.44.1"
ZELLIJ_BIN="$HOME/.local/bin/zellij"
if [ -x "$ZELLIJ_BIN" ] && "$ZELLIJ_BIN" --version 2>/dev/null | grep -qF "${ZELLIJ_VERSION#v}"; then
  log "zellij: $ZELLIJ_VERSION already installed"
else
  log "zellij: downloading $ZELLIJ_VERSION"
  tmp="$(mktemp -d)"
  arch="x86_64-unknown-linux-musl"
  base="https://github.com/zellij-org/zellij/releases/download/${ZELLIJ_VERSION}"
  curl -fsSL -o "$tmp/zellij.tar.gz" "$base/zellij-${arch}.tar.gz"
  curl -fsSL -o "$tmp/zellij.sha256sum" "$base/zellij-${arch}.sha256sum"
  # The published .sha256sum file labels the binary by its CI build path
  # (target/.../zellij), not the tarball name -- so `sha256sum -c` on it
  # fails. Extract the expected hash and verify the extracted binary
  # against it explicitly.
  expected="$(awk '{print $1}' "$tmp/zellij.sha256sum")"
  tar -xzf "$tmp/zellij.tar.gz" -C "$tmp"
  actual="$(sha256sum "$tmp/zellij" | awk '{print $1}')"
  if [ "$expected" != "$actual" ]; then
    printf 'zellij: sha256 mismatch -- expected %s, got %s\n' "$expected" "$actual" >&2
    exit 1
  fi
  mkdir -p "$HOME/.local/bin"
  install -m 0755 "$tmp/zellij" "$ZELLIJ_BIN"
  rm -rf "$tmp"
fi

# ----------------------------------------------------------------- nvm + Node
# Mirror nvm's own install-location logic: $XDG_CONFIG_HOME/nvm if XDG is set,
# else $HOME/.nvm. Set PROFILE=/dev/null so the installer does NOT append to
# any rc file -- the managed .bashrc sources nvm itself.
NVM_VERSION="v0.40.1"
export NVM_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/nvm"
if [ ! -s "$NVM_DIR/nvm.sh" ]; then
  log "nvm: installing $NVM_VERSION to $NVM_DIR"
  curl -fsSL "https://raw.githubusercontent.com/nvm-sh/nvm/${NVM_VERSION}/install.sh" | PROFILE=/dev/null bash
else
  log "nvm: already installed at $NVM_DIR"
fi

# shellcheck disable=SC1091
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"

if ! command -v node >/dev/null 2>&1; then
  log "node: installing LTS via nvm"
  nvm install --lts
  nvm alias default 'lts/*'
else
  log "node: $(node --version) already on PATH"
fi

# ---------------------------------------------------------------- Claude Code
if ! command -v claude >/dev/null 2>&1; then
  log "claude-code: npm install -g @anthropic-ai/claude-code"
  npm install -g @anthropic-ai/claude-code
else
  log "claude-code: already installed"
fi

# ----------------------------------------------------------- Readwise CLI
if ! command -v readwise >/dev/null 2>&1; then
  log "readwise-cli: npm install -g @readwise/cli"
  npm install -g @readwise/cli
else
  log "readwise-cli: already installed"
fi

# ---------------------------------------------------------- rustup + claustre
if ! command -v cargo >/dev/null 2>&1; then
  log "rustup: installing stable toolchain"
  curl -fsSL https://sh.rustup.rs | sh -s -- -y --default-toolchain stable --no-modify-path
fi

# shellcheck disable=SC1091
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

if ! command -v claustre >/dev/null 2>&1; then
  # The repo ships two packages (claustre TUI and claustre-app); cargo requires
  # an explicit package name when installing from a multi-package git source.
  log "claustre: cargo install --git https://github.com/pmbrull/claustre.git claustre"
  cargo install --git https://github.com/pmbrull/claustre.git claustre
else
  log "claustre: already installed"
fi

# ------------------------------------------------------------------- lazygit
# Bookworm apt has lazygit only via backports; take the upstream release for
# parity with zellij. Verified against the per-release checksums.txt.
LAZYGIT_VERSION="v0.61.1"
LAZYGIT_BIN="$HOME/.local/bin/lazygit"
if [ -x "$LAZYGIT_BIN" ] && "$LAZYGIT_BIN" --version 2>/dev/null | grep -qF "${LAZYGIT_VERSION#v}"; then
  log "lazygit: $LAZYGIT_VERSION already installed"
else
  log "lazygit: downloading $LAZYGIT_VERSION"
  tmp="$(mktemp -d)"
  base="https://github.com/jesseduffield/lazygit/releases/download/${LAZYGIT_VERSION}"
  asset="lazygit_${LAZYGIT_VERSION#v}_linux_x86_64.tar.gz"
  curl -fsSL -o "$tmp/$asset" "$base/$asset"
  curl -fsSL -o "$tmp/checksums.txt" "$base/checksums.txt"
  expected="$(awk -v f="$asset" '$2 == f {print $1}' "$tmp/checksums.txt")"
  if [ -z "$expected" ]; then
    printf 'lazygit: no checksum entry for %s in checksums.txt\n' "$asset" >&2
    exit 1
  fi
  actual="$(sha256sum "$tmp/$asset" | awk '{print $1}')"
  if [ "$expected" != "$actual" ]; then
    printf 'lazygit: sha256 mismatch -- expected %s, got %s\n' "$expected" "$actual" >&2
    exit 1
  fi
  tar -xzf "$tmp/$asset" -C "$tmp" lazygit
  mkdir -p "$HOME/.local/bin"
  install -m 0755 "$tmp/lazygit" "$LAZYGIT_BIN"
  rm -rf "$tmp"
fi

# ---------------------------------------------------------------- zellij dirs
# URL-loaded plugins (see ~/.config/zellij/config.kdl) cache under
# ~/.cache/zellij/. This dir is kept for any locally-staged WASM loaded via
# `file:~/.config/zellij/plugins/<name>.wasm` (e.g. cosign-verified installs).
mkdir -p "$HOME/.config/zellij/plugins"

log "bootstrap complete"
