#!/usr/bin/env bash
# Registers Uptime Robot's remote MCP with Claude Code. UR uses bearer-token
# auth (not OAuth like the Cloudflare MCPs in script 07-before), so the token
# is passed via --header and ends up baked into ~/.claude.json.
#
# Why run_onchange_after instead of run_once_before:
#   - _after_: the chezmoi-encrypted token must be decrypted to
#     ~/.config/uptimerobot/token before we read it, which only happens after
#     files are applied.
#   - run_onchange (keyed on the encrypted file's hash below): when the token
#     rotates, the source file's hash changes, this script reruns, and the
#     stale token in ~/.claude.json gets replaced.
#
# Rerun-on-rotation trigger: hash of the encrypted source file embedded
# below. When the user rotates the token and re-runs `chezmoi add --encrypt`,
# the source file changes, this hash changes, the rendered script content
# changes, and chezmoi reruns this script -- which removes the stale
# ~/.claude.json entry and re-adds the new one. The `with` guard keeps the
# template renderable before the user has run `chezmoi add` for the first
# time.
# token-hash: {{ with (glob (joinPath .chezmoi.sourceDir "dot_config/private_uptimerobot/encrypted_private_token.age")) }}{{ include "dot_config/private_uptimerobot/encrypted_private_token.age" | sha256sum }}{{ else }}not-yet-encrypted{{ end }}

set -euo pipefail

log() { printf '==> %s\n' "$*" >&2; }

token_file="$HOME/.config/uptimerobot/token"
if [ ! -r "$token_file" ]; then
  log "uptimerobot: token not deployed at $token_file, skipping"
  exit 0
fi

token="$(<"$token_file")"

# Idempotent re-register: remove any existing entry (no-op if absent) and add
# afresh so a rotated token replaces the stale one in ~/.claude.json.
claude mcp remove uptimerobot --scope user >/dev/null 2>&1 || true
log "uptimerobot: registering"
claude mcp add uptimerobot --transport http --scope user \
  --header "Authorization: Bearer ${token}" \
  https://mcp.uptimerobot.com/mcp
